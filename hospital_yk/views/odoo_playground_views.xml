<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_odoo_playground_form" model="ir.ui.view">
        <field name="name">odoo.playground.form</field>
        <field name="model">odoo.playground</field>
        <field name="arch" type="xml">
            <form string="Odoo Playground">
                <header>
                    <button name="action_execute"
                            string="Execute"
                            type="object"
                            class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="model_id" string="Model (Optional)"/>
                        <h2><field name="model_id" options="{'no_create': True, 'no_open': True}"/></h2>
                    </div>
                    <group>
                        <field name="code"
                               nolabel="1"
                               placeholder="Enter Python code here..."/>
                    </group>
                    <group>
                        <field name="result"
                               nolabel="1"
                               readonly="1"
                               placeholder="Result will appear here..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_playground" model="ir.actions.act_window">
        <field name="name">Playground</field>
        <field name="res_model">odoo.playground</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>
</odoo>
