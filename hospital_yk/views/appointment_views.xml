<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_hospital_appointment_list" model="ir.ui.view">
        <field name="name">hospital.appointment.list</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <list string="Appointments" multi_edit="1">
                <field name="id"/>
                <field name="reference"/>
                <field name="gender" optional="show"/>
                <field name="appointment_date"/>
                <field name="activity_ids" widget="list_activity"/>
                <field name="state"/>
                <field name="notes" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_hospital_appointment_form" model="ir.ui.view">
        <field name="name">hospital.appointment.form</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <form string="Appointments">
                <header>
                    <field name="state" widget="statusbar"/>
                    <button name="action_confirm" type="object" string="Confirm"
                            modifiers="{'visible': [['state', '=', 'draft']]}" class="btn-primary"/>
                    <button name="action_done" type="object" string="Done"
                            modifiers="{'visible': [['state', '=', 'ongoing']]}" class="btn-success"/>
                    <button name="action_ongoing" type="object" string="Set to Ongoing"
                            modifiers="{'visible': [['state', '=', 'confirmed']]}" class="btn-info"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            modifiers="{'visible': [['state', 'in', ['draft', 'confirmed']]]}" class="btn-danger"/>
                    <button name="action_set_draft" type="object" string="Set to Draft"
                            modifiers="{'visible': [['state', 'in', ['cancelled', 'done']]]}" class="btn-secondary"/>
                </header>
                 <div>
                        <button name="action_share_whatsapp" type="object" string="Share via WhatsApp"
                                class="btn-warning" icon="fa-whatsapp"/>
                        <button name="duplicate_records" type="object" string="Duplicate"
                                class="btn-default" icon="fa-copy"/>
                    </div>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="priority" widget="priority" class="mr-3"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="reference" readonly="1"/>
                        </group>
                        <group>
                            <field name="patient_id"/>
                            <field name="appointment_date"/>
                        </group>
                        <group>
                            <field name="gender"/>
                            <field name="notes"/>
                        </group>
                    </group>
                </sheet>

                <notebook>
                    <page string="Prescription">
                        <field name="appointment_line_ids">
                            <list string="Appointment Lines">
                                <field name="product_id"/>
                                <field name="quantity"/>
                                <field name="price"/>
                                <field name="total" readonly="1"/>
                            </list>
                            <form>
                                <field name="product_id"/>
                                <field name="quantity"/>
                                <field name="price"/>
                                <field name="total" readonly="1"/>
                            </form>
                        </field>
                    </page>
                    <page string="Other Details">
                        <field name="other_details" placeholder="Enter your details"
                               options="{'collaborative': true, 'resizable': true, 'codeview': true}"/>
                    </page>
                </notebook>

                <chatter>
                    <field name="message_follower_ids" groups="base.group_user"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <record id="view_hospital_appointment_kanban" model="ir.ui.view">
        <field name="name">hospital.appointment.kanban</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column">
                <!-- 🔧 Declare fields to load their values -->
                <field name="reference"/>
                <field name="appointment_date"/>
                <field name="state"/>
                <field name="patient_id"/>

                <templates>
                    <t t-name="kanban-box">
                        <div class="o_kanban_record">
                            <div class="o_kanban_details mt-2">
                                <strong>
                                    <t t-esc="record.reference and record.reference.value or 'New'"/>
                                </strong>
                                <div>
                                    <t t-esc="'Date: ' + (record.appointment_date and record.appointment_date.value or 'No Date')"/>
                                </div>
                                <div>
                                    <t t-esc="'Status: ' + (record.state and record.state.value or 'No State')"/>
                                </div>
                                <div>
                                    <t t-esc="'Patient: ' + (record.patient_id and record.patient_id.display_name or 'Unknown')"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ✅ Calendar View -->
    <record id="view_hospital_appointment_calendar" model="ir.ui.view">
        <field name="name">hospital.appointment.calendar</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <calendar string="Appointments" date_start="appointment_date" color="state">
                <field name="reference"/>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>
    <!-- ✅ Activity View for Appointments -->
    <record id="view_hospital_appointment_activity" model="ir.ui.view">
        <field name="name">hospital.appointment.activity</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <activity string="Appointments Activity">
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="appointment_date"/>
                <field name="state"/>
                <templates>
                    <t t-name="activity-box">
                        <div class="o_activity_appointment_box d-flex align-items-center">
                            <img t-att-src="activity_image('hospital.patient', 'image', record.patient_id.raw_value)"
                                 t-att-title="record.patient_id.display_name"
                                 class="o_activity_appointment_image me-3 rounded-circle"
                                 style="width: 48px; height: 48px; object-fit: cover;" alt="activity_icon"/>
                            <div class="o_activity_details">
                                <strong>
                                    <t t-esc="record.patient_id and record.patient_id.display_name or 'Unknown Patient'"/>
                                </strong>
                                <br/>
                                <span t-esc="'Doctor: ' + (record.doctor_id and record.doctor_id.display_name or 'Unassigned')"/>
                                <br/>
                                <span t-esc="'Date: ' + (record.appointment_date and record.appointment_date.value or 'No Date')"/>
                                <br/>
                                <span t-esc="'State: ' + (record.state and record.state.value or 'N/A')"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </activity>
        </field>
    </record>


    <!-- ✅ Pivot View (fixed measure) -->
    <record id="view_hospital_appointment_pivot" model="ir.ui.view">
        <field name="name">hospital.appointment.pivot</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <pivot string="Appointments">
                <field name="patient_id" type="row"/>
                <field name="doctor_id" type="row"/>
                <field name="state" type="col"/>
                <field name="duration_hours" type="measure"/>
            </pivot>
        </field>
    </record>


    <record id="view_hospital_appointment_search" model="ir.ui.view">
        <field name="name">hospital.appointment.search</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <search string="Appointments">
                <field name="reference"/>
                <field name="appointment_date"/>
                <field name="patient_id"/>
            </search>
        </field>
    </record>

    <record id="action_hospital_appointment" model="ir.actions.act_window">
        <field name="name">Appointment</field>
        <field name="res_model">hospital.appointment</field>
        <field name="view_mode">list,form,kanban,calendar,activity,pivot,search</field>
        <field name="help" type="html">
            <p class="oe_view_no_content_smiling_face">
                Create a new appointment
            </p>
        </field>
    </record>
</odoo>
