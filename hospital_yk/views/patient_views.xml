<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- List View -->
    <record id="view_hospital_patient_list" model="ir.ui.view">
        <field name="name">hospital.patient.list</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <list string="Patients" export_xlsx="0">
                <field name="id"/>
                <field name="reference"/>
                <field name="name"/>
                <field name="age"/>
                <field name="appointment_count" sum="Total Appointment"/>
                <field name="gender" optional="show"/>
                <field name="doctor_id" widget="many2one_avatar_user"/>
                <field name="tag_ids" optional="hide"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_hospital_patient_form" model="ir.ui.view">
        <field name="name">hospital.patient.form</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <form string="Patients">
                <header>
                    <button name="custom_method" string="Custom Action" type="object" class="btn-primary"/>
                </header>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <group>
                        <group>
                            <field name="reference" readonly="1"/>
                            <field name="name"/>
                            <field name="date_of_birth"/>
                            <field name="age" readonly="1"/>
                            <field name="appointment_count"/>
                            <field name="doctor_id" widget="many2one_avatar_user"/>
                            <field name="guardian"
                                   modifiers="{'invisible': [('age', '>', 18), ('gender', '=', 'male')]}"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                        <group>
                            <field name="gender"/>
                            <field name="tag_ids" widget="many2many_tags"/>
                            <field name="mobile" widget="phone"/>
                            <field name="email" widget="email"/>
                            <field name="guardian_name"/>
                            <field name="guardian_mobile"/>
                            <field name="address"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Medical Details">
                            <group>
                                <field name="medical_history"/>
                                <field name="meditation"/>
                                <field name="dosage"/>
                                <field name="instructions"/>
                            </group>
                        </page>
                        <page string="Other Details">
                            <field name="other_details"
                                   placeholder="Enter any additional notes"
                                   options="{'collaborative': true, 'resizable': true}"/>
                        </page>
                    </notebook>
                    <chatter>
                        <field name="message_follower_ids" groups="base.group_user"/>
                        <field name="message_ids"/>
                    </chatter>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_hospital_patient_kanban" model="ir.ui.view">
        <field name="name">hospital.patient.kanban</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column">
                <!-- 🔧 Add all needed fields here -->
                <field name="image"/>
                <field name="name"/>
                <field name="reference"/>
                <field name="age"/>
                <field name="gender"/>
                <field name="doctor_id"/>

                <templates>
                    <t t-name="kanban-box">
                        <div class="o_kanban_record">
                            <div class="o_kanban_image">
                                <img t-att-src="kanban_image('hospital.patient', 'image', record.id.raw_value)"
                                     class="o_kanban_image_img"
                                     t-att-title="record.name and record.name.value or 'Unnamed Patient'"/>
                            </div>
                            <div class="o_kanban_details mt-2">
                                <strong>
                                    <t t-esc="record.name and record.name.value or 'Unnamed Patient'"/>
                                </strong>
                                <div>
                                    <t t-esc="'Reference: ' + (record.reference and record.reference.value or 'N/A')"/>
                                </div>
                                <div>
                                    <t t-esc="'Age: ' + (record.age and record.age.value or 'N/A')"/>
                                </div>
                                <div>
                                    <t t-esc="'Gender: ' + (record.gender and record.gender.value or 'N/A')"/>
                                </div>
                                <div>
                                    <t t-esc="'Doctor: ' + (record.doctor_id and record.doctor_id.display_name or 'Unassigned')"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Calendar View -->
    <record id="view_hospital_patient_calendar" model="ir.ui.view">
        <field name="name">hospital.patient.calendar</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <calendar string="Patients" date_start="date_of_birth" color="gender">
                <field name="name"/>
                <field name="gender"/>
            </calendar>
        </field>
    </record>

    <!-- ✅ Activity View for Patients -->
    <record id="view_hospital_patient_activity" model="ir.ui.view">
        <field name="name">hospital.patient.activity</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <activity string="Patient Activities">
                <field name="name"/>
                <field name="image"/>
                <field name="gender"/>
                <field name="doctor_id"/>
                <templates>
                    <t t-name="activity-box">
                        <div class="o_activity_patient_box d-flex align-items-center">
                            <img t-att-src="activity_image('hospital.patient', 'image', record.id.raw_value)"
                                 t-att-title="record.display_name"
                                 class="o_activity_patient_image me-3 rounded-circle"
                                 style="width: 48px; height: 48px; object-fit: cover;" alt="profile icon"/>
                            <div class="o_activity_details">
                                <strong>
                                    <t t-esc="record.display_name or 'Unnamed Patient'"/>
                                </strong>
                                <br/>
                                <span t-esc="'Gender: ' + (record.gender and record.gender.value or 'N/A')"/>
                                <br/>
                                <span t-esc="'Doctor: ' + (record.doctor_id and record.doctor_id.display_name or 'Unassigned')"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </activity>
        </field>
    </record>


    <!-- Pivot View -->
    <record id="view_hospital_patient_pivot" model="ir.ui.view">
        <field name="name">hospital.patient.pivot</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <pivot string="Patients">
                <field name="name" type="row"/>
                <field name="gender" type="col"/>
                <field name="age" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_hospital_patient_search" model="ir.ui.view">
        <field name="name">hospital.patient.search</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <search string="Patients">
                <field name="reference"/>
                <field name="name"/>
                <field name="date_of_birth"/>
                <field name="gender"/>
                <field name="tag_ids"/>
                <separator/>
                <filter name="filter_male" string="Male" domain="[('gender', '=', 'male')]"/>
                <filter name="filter_female" string="Female" domain="[('gender', '=', 'female')]"/>
                <separator/>
                <filter name="filter_archived" string="Archived" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_gender" string="Gender" context="{'group_by': 'gender'}"/>
                </group>
                <searchpanel>
                    <field name="gender" icon="fa-users" select="multi" enable_counters="1"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_hospital_patient" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="res_model">hospital.patient</field>
        <field name="view_mode">list,form,kanban,calendar,activity,pivot,search</field>
        <field name="help" type="html">
            <p class="oe_view_no_content_smiling_face">
                Create a new patient
            </p>
        </field>
    </record>
</odoo>
