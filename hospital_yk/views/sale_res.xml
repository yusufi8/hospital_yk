<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_sale_order_form_inherit_hms" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.hms</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

<!--            &lt;!&ndash; Hide the entire order_line page when the sale is confirmed &ndash;&gt;-->
<!--            <xpath expr="//page[.//field[@name='order_line']]" position="attributes">-->
<!--                <attribute name="invisible">state == 'sale'</attribute>-->
<!--            </xpath>-->

            <!-- Make order lines readonly when confirmed (fallback for existing views) -->
            <xpath expr="//field[@name='order_line']" position="attributes">
                <attribute name="readonly">state == 'sale'</attribute>
            </xpath>

<!--             Make the list control buttons invisible when sale is confirmed -->
            <xpath expr="//field[@name='order_line']/list/control/create[@name='add_product_control']"
                   position="attributes">
                <attribute name="readonly">parent.state == 'sale'</attribute>
            </xpath>

            <xpath expr="//field[@name='order_line']/list/control/create[@name='add_section_control']"
                   position="attributes">
                <attribute name="readonly">parent.state == 'sale'</attribute>
            </xpath>

            <xpath expr="//field[@name='order_line']/list/control/create[@name='add_note_control']"
                   position="attributes">
                <attribute name="readonly">parent.state == 'sale'</attribute>
            </xpath>

            <xpath expr="//field[@name='order_line']/list/control/button[@name='action_add_from_catalog']"
                   position="attributes">
                <attribute name="readonly">parent.state == 'sale'</attribute>
            </xpath>
        </field>
    </record>

    <record id="action_sale_orders" model="ir.actions.act_window">
        <field name="name">Sales Orders</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', 'in', ('draft', 'sent'))]</field>
        <field name="help" type="html">
            <p class="o_view_no_content_smiling_face">
                Create and manage your sales orders here.
            </p>
        </field>
    </record>
</odoo>