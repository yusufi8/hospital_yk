<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_patient_reassign_wizard_form" model="ir.ui.view">
        <field name="name">hospital.patient.reassign.wizard.form</field>
        <field name="model">hospital.patient.reassign.wizard</field>
        <field name="arch" type="xml">
            <form string="Reassign Patients">
                <sheet>
                    <group>
                        <group>
                            <field name="old_doctor_id"/>
                            <field name="new_doctor_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="patient_ids" nolabel="1">
                            <tree>
                                <field name="reference"/>
                                <field name="name"/>
                                <field name="age"/>
                                <field name="gender"/>
                            </tree>
                        </field>
                    </group>
                </sheet>
                <footer>
                    <button name="action_reassign"
                            string="Reassign"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>

